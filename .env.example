# MWANGIZ Cosmetics - environment template
# Copy this file to `.env.local` for local development.
# In production (Vercel), set the same keys in Project Settings -> Environment Variables.

# Public (safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://wpcjfkwiqkvvblpmrkli.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_ACCESS_EMAIL=cosmeticsmwangiz@gmail.com

# Server only (never expose to client code)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# M-Pesa Daraja (server only)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
# Optional explicit callback URL. If omitted, app derives from request origin.
MPESA_CALLBACK_URL=
# Optional hardening token. If set, append `?token=<value>` to callback URL in Daraja dashboard.
MPESA_CALLBACK_SECRET=
